{
	"name": "v2 — Vendor App",
	"description": "Vendor mobile app APIs. Flow: Config → Send OTP → Verify OTP → Home → Bookings / Products / Chats / Profile.\n\nBearer token saved as `v2_token`. IDs auto-saved: `v2_booking_id`, `v2_product_id`, `v2_chat_id`.\n\n**Profile:** `coverImage` on `/v2/auth/me` and `POST /v2/auth/profile`. Availability via `is_available` or `POST /v2/profile/availability`.\n\n**Products:** filter by `type` (rented-dress | fashion-designer | rented-jewellery). Each item includes `is_available`.\n\n**Booking detail:** customer email/mobile, full measurements, payment_summary, `customer_review` when delivered.",
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Send OTP",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"if (json.data?.otp) { pm.environment.set('v2_otp', json.data.otp); }"
					] } }],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{v2_mobile}}\",\n  \"type\": \"{{auth_type}}\"\n}" },
						"url": "{{base_url}}/v2/auth/otp/send"
					}
				},
				{
					"name": "Verify OTP",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"if (json.data?.token) { pm.environment.set('v2_token', json.data.token); }",
						"if (json.data?.registration_token) { pm.environment.set('v2_registration_token', json.data.registration_token); }"
					] } }],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{v2_mobile}}\",\n  \"otp\": \"{{v2_otp}}\",\n  \"type\": \"{{auth_type}}\"\n}" },
						"url": "{{base_url}}/v2/auth/otp/verify"
					}
				},
				{
					"name": "Register",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 201', () => pm.response.to.have.status(201));",
						"const json = pm.response.json();",
						"if (json.data?.token) { pm.environment.set('v2_token', json.data.token); }"
					] } }],
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "registration_token", "value": "{{v2_registration_token}}", "type": "text" },
								{ "key": "shop_name", "value": "Riya Rathore Studio", "type": "text" },
								{ "key": "owner_name", "value": "Riya Rathore", "type": "text" },
								{ "key": "email", "value": "riya.vendor@example.com", "type": "text" },
								{ "key": "service_types", "value": "Fashion Designer, Rented Dress", "type": "text" },
								{ "key": "business_mobile", "value": "9876543211", "type": "text" },
								{ "key": "business_mail", "value": "business@riyastudio.com", "type": "text" },
								{ "key": "city", "value": "Indore", "type": "text" },
								{ "key": "aadhar_front", "type": "file", "src": [] },
								{ "key": "aadhar_back", "type": "file", "src": [] }
							]
						},
						"url": "{{base_url}}/v2/auth/register"
					}
				},
				{
					"name": "Me",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{v2_token}}", "type": "string" }] },
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v2/auth/me",
						"description": "Returns `coverImage`, `bio`, `is_available`, and full vendor profile."
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{v2_token}}", "type": "string" }] },
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "owner_name", "value": "Riya Rathore", "type": "text" },
								{ "key": "shop_name", "value": "Riya Rathore Studio", "type": "text" },
								{ "key": "email", "value": "riya.vendor@example.com", "type": "text" },
								{ "key": "city", "value": "Indore", "type": "text" },
								{ "key": "bio", "value": "Fashion designer specialising in bridal and evening wear.", "type": "text" },
								{ "key": "is_available", "value": "1", "type": "text" },
								{ "key": "profile_image", "type": "file", "src": [] },
								{ "key": "coverImage", "type": "file", "src": [], "description": "Shop banner (alias: cover_image)" }
							]
						},
						"url": "{{base_url}}/v2/auth/profile",
						"description": "Update profile with coverImage, bio, is_available, and other fields."
					}
				},
				{
					"name": "Logout",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{v2_token}}", "type": "string" }] },
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v2/auth/logout"
					}
				}
			]
		},
