{
	"info": {
		"_postman_id": "just-book-it-api-collection",
		"name": "Just Book IT — Mobile API",
		"description": "Customer (v1), Vendor (v2), and Driver (v3) APIs.\n\n**Base URL:** `{{base_url}}`\n\n**Suggested v1 flow:** Guest session (or OTP login) → Home → Catalog → Catalog Detail → Booking Preview → Create Booking → Payment Summary → Pay Now → Booking History\n\n**OTP:** Random 4-digit code in Send OTP response (`data.otp`); saved to `v1_otp`.\n\n**Auto-saved IDs:** `v1_portfolio_item_id`, `v1_designer_id`, `v1_booking_id` from list/detail responses.\n\nImport with **Just Book IT — Local** environment. Tokens saved after Verify OTP / Register / Guest.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000/api"
		}
	],
	"item": [
		{
			"name": "v1 — User (Customer)",
			"item": [
				{
					"name": "Auth",
					"item": [
						{
							"name": "Get Config",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 200', () => pm.response.to.have.status(200));",
											"const json = pm.response.json();",
											"pm.test('success is true', () => pm.expect(json.success).to.eql(true));"
										]
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/config"
							}
						},
						{
							"name": "Send OTP",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 200', () => pm.response.to.have.status(200));",
											"const json = pm.response.json();",
											"if (json.data?.otp) { pm.environment.set('v1_otp', json.data.otp); }"
										]
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{ "key": "Accept", "value": "application/json" },
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"mobile\": \"{{v1_mobile}}\",\n  \"type\": \"{{auth_type}}\"\n}"
								},
								"url": "{{base_url}}/v1/auth/otp/send"
							}
						},
						{
							"name": "Verify OTP",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 200', () => pm.response.to.have.status(200));",
											"const json = pm.response.json();",
											"if (json.data?.token) { pm.environment.set('v1_token', json.data.token); }",
											"if (json.data?.registration_token) { pm.environment.set('v1_registration_token', json.data.registration_token); }"
										]
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{ "key": "Accept", "value": "application/json" },
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"mobile\": \"{{v1_mobile}}\",\n  \"otp\": \"{{v1_otp}}\",\n  \"type\": \"{{auth_type}}\"\n}"
								},
								"url": "{{base_url}}/v1/auth/otp/verify"
							}
						},
						{
							"name": "Register",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 201', () => pm.response.to.have.status(201));",
											"const json = pm.response.json();",
											"if (json.data?.token) { pm.environment.set('v1_token', json.data.token); }"
										]
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{ "key": "Accept", "value": "application/json" },
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"registration_token\": \"{{v1_registration_token}}\",\n  \"name\": \"Test Customer\",\n  \"mobile_no\": \"{{v1_mobile}}\",\n  \"email\": \"customer@example.com\"\n}"
								},
								"url": "{{base_url}}/v1/auth/register"
							}
						},
						{
							"name": "Guest session",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 201', () => pm.response.to.have.status(201));",
											"const json = pm.response.json();",
											"if (json.data?.token) { pm.environment.set('v1_token', json.data.token); }"
										]
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/auth/guest"
							}
						},
						{
							"name": "Me",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/auth/me"
							}
						},
						{
							"name": "Update Profile",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "POST",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"body": {
									"mode": "formdata",
									"formdata": [
										{ "key": "name", "value": "Updated Customer", "type": "text" },
										{ "key": "mobile_no", "value": "{{v1_mobile}}", "type": "text" },
										{ "key": "email", "value": "customer@example.com", "type": "text" },
										{ "key": "city", "value": "Indore", "type": "text" },
										{ "key": "profile_image", "type": "file", "src": [] }
									]
								},
								"url": "{{base_url}}/v1/auth/profile"
							}
						},
						{
							"name": "Logout",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "POST",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/auth/logout"
							}
						}
					]
				},
				{
					"name": "Home & Discovery",
					"item": [
						{
							"name": "Home",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 200', () => pm.response.to.have.status(200));",
											"const json = pm.response.json();",
											"pm.test('success is true', () => pm.expect(json.success).to.eql(true));",
											"if (json.data?.featured_designers?.[0]?.id) {",
											"    pm.environment.set('v1_designer_id', String(json.data.featured_designers[0].id));",
											"}"
										]
									}
								}
							],
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/home",
								"description": "Public endpoint. Bearer token is optional — sends location when logged in."
							}
						},
						{
							"name": "Categories",
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/categories"
							}
						},
						{
							"name": "Categories (shop roots)",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"const json = pm.response.json();",
											"const id = json.data?.categories?.[0]?.id || json.data?.items?.[0]?.id;",
											"if (id) { pm.environment.set('v1_category_id', String(id)); }"
										]
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/categories?roots=1"
							}
						},
						{
							"name": "Categories (services)",
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/categories?type=service"
							}
						},
						{
							"name": "Search",
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/search?q=pearl"
							}
						},
						{
							"name": "Catalog List",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 200', () => pm.response.to.have.status(200));",
											"const json = pm.response.json();",
											"if (json.data?.items?.[0]?.id) {",
											"    pm.environment.set('v1_portfolio_item_id', String(json.data.items[0].id));",
											"}"
										]
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/catalog?page=1&per_page=12"
							}
						},
						{
							"name": "Catalog List (filtered)",
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/catalog?search=pearl&category_id={{v1_category_id}}&page=1"
							}
						},
						{
							"name": "Catalog Detail",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 200', () => pm.response.to.have.status(200));",
											"const json = pm.response.json();",
											"if (json.data?.id) { pm.environment.set('v1_portfolio_item_id', String(json.data.id)); }"
										]
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/catalog/{{v1_portfolio_item_id}}"
							}
						},
						{
							"name": "Designers List",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"const json = pm.response.json();",
											"if (json.data?.items?.[0]?.id) {",
											"    pm.environment.set('v1_designer_id', String(json.data.items[0].id));",
											"}"
										]
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/designers?featured=1&page=1"
							}
						},
						{
							"name": "Designer Detail",
							"request": {
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/designers/{{v1_designer_id}}"
							}
						}
					]
				},
				{
					"name": "Bookings",
					"item": [
						{
							"name": "Saved Addresses",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/bookings/addresses"
							}
						},
						{
							"name": "Booking Preview",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/bookings/preview/{{v1_portfolio_item_id}}?shipment_required=1"
							}
						},
						{
							"name": "Create Booking (JSON)",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 201', () => pm.response.to.have.status(201));",
											"const json = pm.response.json();",
											"if (json.data?.booking?.id) {",
											"    pm.environment.set('v1_booking_id', String(json.data.booking.id));",
											"}"
										]
									}
								}
							],
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "POST",
								"header": [
									{ "key": "Accept", "value": "application/json" },
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"portfolio_item_id\": {{v1_portfolio_item_id}},\n  \"size\": \"XL\",\n  \"measurement_type\": \"women\",\n  \"customer_notes\": \"Add custom notes for fitting.\",\n  \"delivery_address\": \"G-14 1st sabari nagar, sukhliya, Indore\",\n  \"billing_address\": \"G-14 1st sabari nagar, sukhliya, Indore\",\n  \"city\": \"Indore\",\n  \"pincode\": \"452010\",\n  \"rental_start_date\": \"2026-06-15\",\n  \"rental_end_date\": \"2026-06-17\",\n  \"shipment_required\": true,\n  \"measure_height_cm\": 165,\n  \"measure_chest_cm\": 36,\n  \"measure_waist_cm\": 28\n}"
								},
								"url": "{{base_url}}/v1/bookings"
							}
						},
						{
							"name": "Create Booking (multipart + images)",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Status is 201', () => pm.response.to.have.status(201));",
											"const json = pm.response.json();",
											"if (json.data?.booking?.id) {",
											"    pm.environment.set('v1_booking_id', String(json.data.booking.id));",
											"}"
										]
									}
								}
							],
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "POST",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"body": {
									"mode": "formdata",
									"formdata": [
										{ "key": "portfolio_item_id", "value": "{{v1_portfolio_item_id}}", "type": "text" },
										{ "key": "size", "value": "XL", "type": "text" },
										{ "key": "measurement_type", "value": "women", "type": "text" },
										{ "key": "customer_notes", "value": "Reference style attached.", "type": "text" },
										{ "key": "delivery_address", "value": "G-14 1st sabari nagar, sukhliya, Indore", "type": "text" },
										{ "key": "city", "value": "Indore", "type": "text" },
										{ "key": "pincode", "value": "452010", "type": "text" },
										{ "key": "shipment_required", "value": "1", "type": "text" },
										{ "key": "reference_images[]", "description": "Optional — max 5, JPG/PNG/WebP, 4MB each", "type": "file", "src": [] }
									]
								},
								"url": "{{base_url}}/v1/bookings"
							}
						},
						{
							"name": "Booking History (all)",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/bookings?page=1"
							}
						},
						{
							"name": "Booking History (designers tab)",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/bookings?tab=designers&page=1"
							}
						},
						{
							"name": "Booking History (rental dress tab)",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/bookings?tab=rental_dress&page=1"
							}
						},
						{
							"name": "Booking Detail",
							"event": [
								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"const json = pm.response.json();",
											"if (json.data?.id) { pm.environment.set('v1_booking_id', String(json.data.id)); }"
										]
									}
								}
							],
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/bookings/{{v1_booking_id}}"
							}
						},
						{
							"name": "Cancel Booking",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "POST",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/bookings/{{v1_booking_id}}/cancel"
							}
						}
					]
				},
				{
					"name": "Payment",
					"item": [
						{
							"name": "Payment Methods",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/payment/methods"
							}
						},
						{
							"name": "Payment Summary",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "GET",
								"header": [{ "key": "Accept", "value": "application/json" }],
								"url": "{{base_url}}/v1/payment/bookings/{{v1_booking_id}}"
							}
						},
						{
							"name": "Pay Now (UPI)",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "POST",
								"header": [
									{ "key": "Accept", "value": "application/json" },
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"payment_method\": \"upi\"\n}"
								},
								"url": "{{base_url}}/v1/payment/bookings/{{v1_booking_id}}/pay"
							}
						},
						{
							"name": "Pay Now (COD)",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
								},
								"method": "POST",
								"header": [
									{ "key": "Accept", "value": "application/json" },
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"payment_method\": \"cod\"\n}"
								},
								"url": "{{base_url}}/v1/payment/bookings/{{v1_booking_id}}/pay",
								"description": "Requires `enable_cod` in admin platform settings."
							}
						}
					]
				},
				{
					"name": "Profile",
					"item": [
						{
							"name": "Profile Home",
							"request": {
