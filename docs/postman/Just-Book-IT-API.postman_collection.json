{
	"info": {
		"_postman_id": "just-book-it-api-collection",
		"name": "Just Book IT — Mobile API",
		"description": "Auth APIs for Customer (v1), Vendor (v2), and Driver (v3).\n\n**Base URL:** `{{base_url}}`\n\n**OTP:** Random 4-digit code returned in Send OTP response (`data.otp`); Postman saves it automatically.\n\n**Flow:** Send OTP → Verify OTP → (Register if new) → Me / Update Profile / Logout\n\n**Multipart:** Vendor register, driver register, and all profile updates use `form-data`. Image fields: JPG/PNG/WebP, max 4MB.\n\n**Vendor `service_types`:** Array of category IDs from admin Categories (type: service). Use `service_types[0]`, `service_types[1]`, etc.\n\nTokens and registration tokens are saved automatically when you use the **Just Book IT — Local** environment.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000/api"
		}
	],
	"item": [
		{
			"name": "v1 — User (Customer)",
			"item": [
				{
					"name": "Get Config",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('success is true', () => pm.expect(json.success).to.eql(true));",
									"pm.test('user legal section exists', () => pm.expect(json.data?.user?.terms_and_conditions).to.be.a('string'));",
									"pm.test('faq list returned', () => pm.expect(json.data?.user?.faq).to.be.an('array'));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/config",
						"description": "Public endpoint. Returns terms, privacy policy, and FAQ for user, vendor, and driver apps, plus contact, features, and branding."
					}
				},
				{
					"name": "Send OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('success is true', () => pm.expect(json.success).to.eql(true));",
									"pm.test('user object returned', () => pm.expect(json.data?.user).to.be.an('object'));",
									"if (json.data?.otp) { pm.environment.set('v1_otp', json.data.otp); }"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mobile\": \"{{v1_mobile}}\",\n  \"type\": \"{{auth_type}}\"\n}"
						},
						"url": "{{base_url}}/v1/auth/otp/send",
						"description": "Send OTP to customer mobile. Response includes random `otp` (saved to v1_otp)."
					}
				},
				{
					"name": "Verify OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"if (json.data?.token) {",
									"    pm.environment.set('v1_token', json.data.token);",
									"}",
									"if (json.data?.registration_token) {",
									"    pm.environment.set('v1_registration_token', json.data.registration_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mobile\": \"{{v1_mobile}}\",\n  \"otp\": \"{{v1_otp}}\",\n  \"type\": \"{{auth_type}}\"\n}"
						},
						"url": "{{base_url}}/v1/auth/otp/verify",
						"description": "Existing user → saves `v1_token`. New user → saves `v1_registration_token` for register."
					}
				},
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 201', () => pm.response.to.have.status(201));",
									"const json = pm.response.json();",
									"if (json.data?.token) {",
									"    pm.environment.set('v1_token', json.data.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"registration_token\": \"{{v1_registration_token}}\",\n  \"name\": \"Test Customer\",\n  \"mobile_no\": \"{{v1_mobile}}\",\n  \"email\": \"customer@example.com\"\n}"
						},
						"url": "{{base_url}}/v1/auth/register",
						"description": "Complete registration after OTP verify (new users only). `mobile_no` must match OTP verified number."
					}
				},
				{
					"name": "Guest session",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 201', () => pm.response.to.have.status(201));",
									"const json = pm.response.json();",
									"if (json.data?.token) {",
									"    pm.environment.set('v1_token', json.data.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": "{{base_url}}/v1/auth/guest",
						"description": "Create a guest customer session (no OTP)."
					}
				},
				{
					"name": "Me",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
						},
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/auth/me"
					}
				},
				{
					"name": "Update Profile",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('success is true', () => pm.expect(json.success).to.eql(true));",
									"pm.test('user object returned', () => pm.expect(json.data?.user).to.be.an('object'));"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
						},
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "name", "value": "Updated Customer", "type": "text" },
								{ "key": "mobile_no", "value": "{{v1_mobile}}", "type": "text" },
								{ "key": "email", "value": "customer@example.com", "type": "text" },
								{
									"key": "profile_image",
									"description": "Optional — JPG/PNG/WebP, max 4MB",
									"type": "file",
									"src": []
								}
							]
						},
						"url": "{{base_url}}/v1/auth/profile",
						"description": "Update customer profile. Same fields as register (name, mobile_no, email) plus profile_image. All fields optional."
					}
				},
				{
					"name": "Logout",
					"request": {
						"auth": {
							"type": "bearer",

							"bearer": [{ "key": "token", "value": "{{v1_token}}", "type": "string" }]
						},
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/auth/logout"
					}
				}
			]
		},
